{%- liquid
  assign swiper_settings = section.settings.swiper_settings
  assign show_navigation = true
  assign show_pagination = true

  if swiper_settings != blank
    assign show_navigation = swiper_settings.navigation.value | default: swiper_settings.navigation
    assign show_pagination = swiper_settings.pagination.value | default: swiper_settings.pagination
  endif
-%}

<div
  class="main-swiper"
  data-section-id="{{ section.id }}"
  data-navigation="{{ show_navigation }}"
  data-pagination="{{ show_pagination }}"
>
  {%- for block in section.blocks -%}
    {%- liquid
      assign title = block.settings.title
      assign description = block.settings.description
      assign media_obj = block.settings.media
      assign buttons_list = block.settings.buttons
    -%}

    <div id="slide-{{ section.id }}-{{ forloop.index }}" {{ block.shopify_attributes }}>
      {%- if media_obj != blank -%}
        {%- render 'media', data: media_obj, settings: section.settings -%}
      {%- endif -%}

      {%- if title != blank or description != blank or buttons_list != blank -%}
        <div>
          {%- if title != blank -%}
            <h2>{{ title }}</h2>
          {%- endif -%}
          {%- if description != blank -%}
            <p>{{ description }}</p>
          {%- endif -%}
          {%- if buttons_list != blank and buttons_list.size > 0 -%}
            <div>
              {%- for btn in buttons_list -%}
                {%- render 'button', data: btn -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "t:sections.main_swiper.name",
  "tag": "section",
  "class": "section main-banner-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "metaobject",
      "id": "swiper_settings",
      "label": "t:sections.main_swiper.settings.swiper_settings.label",
      "metaobject_type": "swiper_settings"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.main_swiper.blocks.slide.name",
      "limit": 10,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.main_swiper.blocks.slide.settings.header_heading.content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.main_swiper.blocks.slide.settings.title.label",
          "default": "t:sections.main_swiper.blocks.slide.settings.title.default"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.main_swiper.blocks.slide.settings.description.label",
          "default": "t:sections.main_swiper.blocks.slide.settings.description.default"
        },
        {
          "type": "header",
          "content": "t:sections.main_swiper.blocks.slide.settings.header_media.content"
        },
        {
          "type": "metaobject",
          "id": "media",
          "label": "t:sections.main_swiper.blocks.slide.settings.media.label",
          "metaobject_type": "media"
        },
        {
          "type": "header",
          "content": "t:sections.main_swiper.blocks.slide.settings.header_layout.content"
        },
        {
          "type": "metaobject",
          "id": "layout",
          "label": "t:sections.main_swiper.blocks.slide.settings.layout.label",
          "metaobject_type": "layout"
        },
        {
          "type": "header",
          "content": "t:sections.main_swiper.blocks.slide.settings.header_button.content"
        },
        {
          "type": "metaobject_list",
          "id": "buttons",
          "label": "t:sections.main_swiper.blocks.slide.settings.buttons.label",
          "metaobject_type": "button"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_swiper.presets.name",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "t:sections.main_swiper.blocks.slide.settings.title.default",
            "description": "t:sections.main_swiper.blocks.slide.settings.description.default"
          }
        }
      ]
    }
  ]
}
{% endschema %}
