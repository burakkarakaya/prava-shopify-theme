<div class="featured-categories">
  <div>
    {%- if section.settings.heading != blank -%}
      <h2>{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <div>{{ section.settings.description }}</div>
    {%- endif -%}
  </div>

  <div>
    {%- for block in section.blocks -%}
      {%- assign collection = block.settings.collection -%}
      {%- if collection != blank -%}
        <div {{ block.shopify_attributes }}>
          {%- render 'collection-card',
            collection: collection,
            button_text: block.settings.button_text
          -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.featured-categories.name",
  "tag": "section",
  "class": "featured-categories-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured-categories.settings.heading.label",
      "default": "t:sections.featured-categories.settings.heading.default"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.featured-categories.settings.description.label"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "t:sections.featured-categories.blocks.category.name",
      "limit": 12,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.featured-categories.blocks.category.settings.collection.label"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "t:sections.featured-categories.blocks.category.settings.button_text.label",
          "default": "t:sections.featured-categories.blocks.category.settings.button_text.default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-categories.presets.name",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
