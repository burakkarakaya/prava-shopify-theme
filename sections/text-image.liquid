<div class="text-image-section">
  {%- liquid
    assign layout = section.settings.layout
    if layout == 'text_left'
      assign text_first = true
    else
      assign text_first = false
    endif
  -%}
  <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center;">
    {%- if text_first -%}
      <div style="flex: 1; min-width: 280px;">
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div>{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
      {%- if section.settings.image != blank -%}
        <div style="flex: 1; min-width: 280px;">
          <img
            src="{{ section.settings.image | image_url: width: 960 }}"
            alt="{{ section.settings.image.alt | escape }}"
            width="960"
            height="{{ 960 | divided_by: section.settings.image.aspect_ratio | round }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}
    {%- else -%}
      {%- if section.settings.image != blank -%}
        <div style="flex: 1; min-width: 280px;">
          <img
            src="{{ section.settings.image | image_url: width: 960 }}"
            alt="{{ section.settings.image.alt | escape }}"
            width="960"
            height="{{ 960 | divided_by: section.settings.image.aspect_ratio | round }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}
      <div style="flex: 1; min-width: 280px;">
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div>{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.text-image.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.text-image.settings.heading.label"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.text-image.settings.text.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.text-image.settings.image.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.text-image.settings.layout.label",
      "options": [
        { "value": "text_left", "label": "t:sections.text-image.settings.layout.options.text_left" },
        { "value": "image_left", "label": "t:sections.text-image.settings.layout.options.image_left" }
      ],
      "default": "text_left"
    }
  ],
  "presets": [
    {
      "name": "t:sections.text-image.presets.name"
    }
  ]
}
{% endschema %}
